<Window x:Class="ZabbixTrayMonitor.ZabbixConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZabbixTrayMonitor"
        mc:Ignorable="d"
        Title="Zabbix Einstellungen"
        SizeToContent="Height"
        Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="6" MinHeight="260">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Einstellungen"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}" />

        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" /> 
                    <RowDefinition Height="Auto" /> 
                    <RowDefinition Height="Auto" /> 
                    <RowDefinition Height="Auto" />
                <RowDefinition Height="4" /> 
                    <RowDefinition Height="Auto" /> 
                </Grid.RowDefinitions>

                <!-- Zabbix URL -->
                <TextBlock 
                    Grid.Row="0" 
                    Grid.Column="0" 
                    Foreground="{DynamicResource SecondaryTextBrush}" 
                    Margin="0,6,0,2" 
                    VerticalAlignment="Center">
                    <Run Text="Zabbix URL" />
                    <Run Text=" *" 
                         Foreground="#FF4C4C" 
                         FontWeight="Bold" 
                         ToolTip="Pflichtfeld" />
                </TextBlock>
                <TextBox Grid.Row="0" 
                         Grid.Column="1" 
                         x:Name="ZabbixUrlTextBox" 
                         Height="30" 
                         Padding="6" 
                         Margin="0,0,0,8" 
                         HorizontalAlignment="Stretch" 
                         VerticalAlignment="Center" />

                <!-- Dashboard URL -->
                <TextBlock 
                    Grid.Row="1" 
                    Grid.Column="0" 
                    Text="Dashboard URL" 
                    Foreground="{DynamicResource SecondaryTextBrush}" 
                    Margin="0,6,0,2" 
                    VerticalAlignment="Center" />
                <TextBox 
                    Grid.Row="1" 
                    Grid.Column="1" 
                    x:Name="ZabbixDashboardUrlTextBox" 
                    Height="30" 
                    Padding="6" 
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Center" />

                <!-- API Token -->
                <TextBlock 
                    Grid.Row="2" 
                    Grid.Column="0" 
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Margin="0,6,0,2" 
                    VerticalAlignment="Center">
                    <Run Text="API Token" />
                    <Run Text=" *" 
                         Foreground="#FF4C4C" 
                         FontWeight="Bold" 
                         ToolTip="Pflichtfeld" />
                </TextBlock>
                <PasswordBox 
                    Grid.Row="2" 
                    Grid.Column="1"
                    x:Name="ApiTokenTextBox"
                    Height="30" Padding="6" 
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Center" />

                <!-- Optionen -->
                <TextBlock 
                    Grid.Row="3" 
                    Grid.Column="0" 
                    Text="Optionen" 
                    Foreground="{DynamicResource SecondaryTextBrush}" 
                    Margin="0,6,0,2" 
                    VerticalAlignment="Top" />
                <StackPanel 
                    Grid.Row="3" 
                    Grid.Column="1" 
                    Orientation="Vertical" 
                    Margin="0,0,0,8" 
                    VerticalAlignment="Top">
                    <CheckBox x:Name="IgnoreCertificateErrorsCheckBox" Content="SSL nutzen" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,2" />
                    <CheckBox x:Name="DarkModeCheckBox" Content="Dark Mode aktivieren" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,2" />
                </StackPanel>

                <!-- Abfrageintervall -->
                <TextBlock 
                    Grid.Row="4" 
                    Grid.Column="0" 
                    Foreground="{DynamicResource SecondaryTextBrush}" 
                    Margin="0,6,0,2" 
                    VerticalAlignment="Center">
                    <Run Text="Abfrageintervall (s)" />
                    <Run Text=" *" Foreground="#FF4C4C" FontWeight="Bold" ToolTip="Pflichtfeld" />
                </TextBlock>
                <TextBox 
                    Grid.Row="4" 
                    Grid.Column="1"
                    x:Name="PollIntervalSecondsTextBox" 
                    Width="160" Height="30" Padding="6"
                    Text="60" HorizontalAlignment="Left" 
                    VerticalAlignment="Center" />

                <!-- Buttons -->
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button 
                        Content="Testen" 
                        Width="80" Margin="0,0,8,0"
                        Click="TestConnection_Click" />
                    <Button 
                        Content="Abbrechen" 
                        Width="90" Margin="0,0,8,0"
                        Click="Cancel_Click" />
                    <Button 
                        Content="Speichern" 
                        Width="90" 
                        Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
