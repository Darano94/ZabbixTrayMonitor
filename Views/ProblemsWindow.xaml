<Window x:Class="ZabbixTrayMonitor.Views.ProblemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Aktuelle Zabbix Probleme"
        Height="460"
        Width="300"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="ProblemItemBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0" Y="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="0"
                                      ShadowDepth="0"
                                      Opacity="0" />
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform X="0" Y="-2" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="2"
                                              Color="{DynamicResource HoverShadowColor}"
                                              Opacity="0.12" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Border CornerRadius="8"
                Background="{DynamicResource WindowBackgroundBrush}"
                Padding="12"
                Margin="8"
                Effect="{x:Null}">

            <!-- Outer panel -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">

                        <TextBlock x:Name="LoadingTextBlock"
                                   Visibility="Collapsed"
                                   Foreground="{DynamicResource LoadingBrush}"
                                   FontStyle="Italic"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="Aktualisiere..." />

                        <TextBlock x:Name="LastUpdatedTextBlock"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">

                        <Button Content="⟳"
                                Width="26"
                                Height="24"
                                MinWidth="0"
                                Margin="0,0,6,0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="0"
                                ToolTip="Aktualisieren"
                                Click="Refresh_Click" />

                        <Button Content="⌂"
                                Width="26"
                                Height="24"
                                MinWidth="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="0"
                                ToolTip="Dashboard öffnen"
                                Click="Dashboard_Click" />
                    </StackPanel>
                </Grid>

                <!-- Content -->
                <Grid Grid.Row="1">
                    <TextBlock x:Name="EmptyTextBlock"
                               Visibility="Collapsed"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="Keine Probleme gefunden" />

                    <ScrollViewer x:Name="ProblemsScrollViewer"
                                  VerticalScrollBarVisibility="Auto">

                        <ItemsControl x:Name="ProblemsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ProblemItemBorderStyle}"
                                            MouseLeftButtonUp="ProblemItem_Click">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="{Binding StatusColor}" />

                                            <StackPanel Grid.Column="1"
                                                        Margin="8,4,4,8">

                                                <TextBlock Text="{Binding Host}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontSize="11" />

                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontWeight="Bold"
                                                           FontSize="13" />

                                                <TextBlock Text="{Binding Name}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontSize="12" />

                                                <TextBlock Text="{Binding Time}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontSize="10"
                                                           Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>