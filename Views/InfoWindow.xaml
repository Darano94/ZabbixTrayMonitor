<Window x:Class="ZabbixTrayMonitor.Views.InfoWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Info - ZabbixTrayMonitor" SizeToContent="WidthAndHeight" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
	<Grid Margin="6">
		<Border CornerRadius="8" Background="{DynamicResource WindowBackgroundBrush}" Padding="12">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="28" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>
				<Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
					<TextBlock x:Name="HeaderTitleInfo" Text="Info" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Bold" VerticalAlignment="Center" />
				</Border>
				<StackPanel Grid.Row="1">
					<TextBlock
						x:Name="AppNameText"
						FontSize="14"
						FontWeight="Bold"
						Foreground="{DynamicResource PrimaryTextBrush}"
						Margin="0,0,0,6" />
					<TextBlock
						x:Name="VersionText"
						Foreground="{DynamicResource SecondaryTextBrush}" />
					<TextBlock
						x:Name="ProgramText"
						Foreground="{DynamicResource SecondaryTextBrush}"
						TextWrapping="Wrap"
						Margin="0,6,0,0" />
					<TextBlock
						x:Name="ConfigText"
						Foreground="{DynamicResource SecondaryTextBrush}"
						TextWrapping="Wrap"
						Margin="0,6,0,0" />
					<Button
						Content="Schließen"
						Width="80"
						HorizontalAlignment="Right"
						Margin="0,12,0,0"
						Click="Close_Click" />
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Window>
