<Window x:Class="ZabbixTrayMonitor.Views.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Info" SizeToContent="WidthAndHeight" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True" Background="{DynamicResource WindowBackgroundBrush}">
    <Border Padding="12">
        <StackPanel>
            <TextBlock x:Name="AppNameText" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
            <TextBlock x:Name="VersionText" Foreground="{DynamicResource SecondaryTextBrush}" />
            <TextBlock x:Name="PathText" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
            <Button Content="Schließen" Width="80" HorizontalAlignment="Right" Margin="0,12,0,0" Click="Close_Click" />
        </StackPanel>
    </Border>
</Window>